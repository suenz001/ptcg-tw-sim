rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Each authenticated user (including Anonymous) can read/write only their
    // own deck sub-collection.
    match /users/{userId}/decks/{deckId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // ── 線上對戰房間 ──────────────────────────────────────────────────────
    match /rooms/{roomCode} {
      // 任何已登入用戶可讀取（用來透過房號加入）
      allow read: if request.auth != null;

      // 只有 host 可以建立房間
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.hostUid;

      // host 或 guest 可以更新（推送狀態、打出動作）
      allow update: if request.auth != null
                    && (request.auth.uid == resource.data.hostUid
                        || request.auth.uid == resource.data.guestUid);
    }
  }
}
