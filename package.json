    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "cheerio": "^1.2.0",
    "firebase-tools": "^15.15.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "firebase": "^12.0.0"
  }
}
